# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
venv/
.venv/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# pd4web build artifacts
public/audio/.build/
public/audio/Pd4Web/
public/audio/WebPatch/

# pd4web standalone files (not used by Next.js app)
public/audio/index.html
public/audio/manifest.json
public/audio/pd4web.sw.js
public/audio/favicon.ico
public/audio/icon-192.png
public/audio/icon-512.png
